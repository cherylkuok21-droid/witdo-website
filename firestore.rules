
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Global Safety Net & Helpers
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'google.com');
    }

    function isAdmin() {
      return isVerified() && request.auth.token.email == "mo.witdo@gmail.com";
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Work Orders Validation
    // ===============================================================
    function isValidWorkOrder(data) {
      return data.customerName is string && data.customerName.size() > 0 && data.customerName.size() <= 300 &&
             data.wechatId is string && data.wechatId.size() > 0 && data.wechatId.size() <= 300 &&
             data.style is string && data.style.size() <= 5000 &&
             (data.couponCode == null || (data.couponCode is string && data.couponCode.size() <= 200)) &&
             data.totalPrice is number && data.totalPrice >= 0 &&
             data.status in ['pending', 'in-progress', 'completed', 'delivered'] &&
             data.ownerUid is string && data.ownerUid == request.auth.uid &&
             (data.workOrderId == null || (data.workOrderId is string && data.workOrderId.size() <= 200)) &&
             (data.nameplateFont == null || (data.nameplateFont is string && data.nameplateFont.size() <= 1000)) &&
             (data.nameplateContent == null || (data.nameplateContent is string && data.nameplateContent.size() <= 2000)) &&
             (data.estimatedCompletionDate == null || (data.estimatedCompletionDate is string && data.estimatedCompletionDate.size() <= 200)) &&
             (data.signatureData == null || (data.signatureData is string && data.signatureData.size() <= 10000000)) && // 10MB for high-res signatures
             (data.signatureTime == null || (data.signatureTime is string && data.signatureTime.size() <= 300)) &&
             (data.updatedAt == request.time);
    }

    match /workOrders/{orderId} {
      allow read: if isVerified() && (isAdmin() || existing().ownerUid == request.auth.uid);
      
      allow create: if isVerified() && 
                      incoming().ownerUid == request.auth.uid && 
                      incoming().orderDate == request.time &&
                      isValidWorkOrder(incoming());
      
      allow update: if isVerified() && 
                      (isAdmin() || existing().ownerUid == request.auth.uid) &&
                      incoming().ownerUid == existing().ownerUid &&
                      isValidWorkOrder(incoming()) &&
                      (
                        // Action: Admin State Change
                        (isAdmin() && incoming().diff(existing()).affectedKeys().hasAny(['status', 'updatedAt'])) ||
                        // Action: Edit Order Details (if not completed)
                        (existing().status != 'delivered' && 
                         incoming().diff(existing()).affectedKeys().hasOnly([
                           'customerName', 'wechatId', 'estimatedCompletionDate', 'style', 'workOrderId',
                           'couponCode', 'nameplateFont', 'nameplateContent', 'totalPrice', 
                           'status', 'signatureData', 'signatureTime', 'updatedAt', 'orderDate'
                         ]))
                      );
      
      allow delete: if isAdmin();
    }

    // ===============================================================
    // Products & Utilities
    // ===============================================================
    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 500 &&
             data.price is number && data.price >= 0 &&
             data.ownerUid is string && data.ownerUid == request.auth.uid;
    }

    match /products/{productId} {
      allow read: if isVerified();
      allow create: if isVerified() && (isAdmin() || incoming().ownerUid == request.auth.uid) && isValidProduct(incoming());
      allow update: if isVerified() && (isAdmin() || existing().ownerUid == request.auth.uid) && isValidProduct(incoming());
      allow delete: if isAdmin() || (isVerified() && existing().ownerUid == request.auth.uid);
    }

    match /presets/{presetId} {
      allow read: if isVerified();
      allow create, update: if isVerified() && (isAdmin() || incoming().ownerUid == request.auth.uid);
      allow delete: if isVerified() && (isAdmin() || existing().ownerUid == request.auth.uid);
    }

    match /discounts/{discountId} {
      allow read: if isVerified();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /nameTagFonts/{fontId} {
      allow read: if isVerified();
      allow write: if isAdmin();
    }
  }
}

