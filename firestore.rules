
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: workOrders
    // Document ID: auto-generated
    // Fields:
    //   - customerName: string (required)
    //   - contactInfo: string (required)
    //   - babyName: string (required)
    //   - babyAge: string (optional)
    //   - castingType: string (required, enum: ['hands', 'feet', 'both'])
    //   - frameChoice: string (optional)
    //   - materialChoice: string (optional)
    //   - orderDate: timestamp (required)
    //   - status: string (required, enum: ['pending', 'in-progress', 'completed', 'delivered'])
    //   - notes: string (optional)
    //   - ownerUid: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "mo.witdo@gmail.com" && request.auth.token.email_verified == true);
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidWorkOrder(data) {
      return data.customerName is string && data.customerName.size() > 0 && data.customerName.size() < 100 &&
             data.contactInfo is string && data.contactInfo.size() > 0 && data.contactInfo.size() < 200 &&
             data.babyName is string && data.babyName.size() > 0 && data.babyName.size() < 100 &&
             data.castingType in ['hands', 'feet', 'both'] &&
             data.status in ['pending', 'in-progress', 'completed', 'delivered'] &&
             data.orderDate is timestamp &&
             data.ownerUid is string && data.ownerUid == request.auth.uid;
    }

    match /workOrders/{orderId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidWorkOrder(request.resource.data);
      allow update: if isAdmin() && isValidWorkOrder(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
