
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: workOrders
    // Document ID: auto-generated
    // Fields:
    //   - customerName: string (required)
    //   - wechatId: string (required)
    //   - estimatedCompletionDate: string (optional)
    //   - style: string (required)
    //   - nameplateFont: string (optional)
    //   - nameplateContent: string (optional)
    //   - orderDescription: string (optional)
    //   - options: string (optional)
    //   - unitPrice: number (optional)
    //   - totalPrice: number (required)
    //   - orderDate: timestamp (required)
    //   - status: string (required, enum: ['pending', 'in-progress', 'completed', 'delivered'])
    //   - signatureData: string (optional)
    //   - signatureTime: string (optional)
    //   - ownerUid: string (required)
    //
    // Collection: products
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - price: number (required)
    //   - options: list (optional)
    //   - ownerUid: string (required)
    //
    // Collection: presets
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - values: list (required)
    //   - ownerUid: string (required)
    //
    // Collection: discounts
    // Document ID: auto-generated
    // Fields:
    //   - code: string (required)
    //   - type: string (required, enum: ['percentage', 'fixed'])
    //   - value: number (required)
    //   - applicableProductIds: list (required)
    //   - ownerUid: string (required)
    //
    // Collection: nameTagFonts
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - imageUrl: string (required)
    //   - ownerUid: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "mo.witdo@gmail.com"); 
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidWorkOrder(data) {
      return data.customerName is string && data.customerName.size() > 0 && data.customerName.size() < 100 &&
             data.wechatId is string && data.wechatId.size() > 0 && data.wechatId.size() < 100 &&
             data.style is string && data.style.size() > 0 && data.style.size() < 1000 &&
             (data.couponCode == null || (data.couponCode is string && data.couponCode.size() < 50)) &&
             data.totalPrice is number && data.totalPrice >= 0 &&
             data.status in ['pending', 'in-progress', 'completed', 'delivered'] &&
             (data.orderDate is timestamp || data.orderDate == null) &&
             data.ownerUid is string && data.ownerUid == request.auth.uid;
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.ownerUid is string && data.ownerUid == request.auth.uid;
    }

    function isValidPreset(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.values is list && data.values.size() >= 0 &&
             data.ownerUid is string && data.ownerUid == request.auth.uid;
    }

    function isValidDiscount(data) {
      return data.code is string && data.code.size() > 0 && data.code.size() < 50 &&
             data.type in ['percentage', 'fixed'] &&
             data.value is number && data.value >= 0 &&
             data.applicableProductIds is list &&
             data.ownerUid is string && data.ownerUid == request.auth.uid;
    }

    function isValidNameTagFont(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.imageUrl is string && data.imageUrl.size() > 0 &&
             data.ownerUid is string && data.ownerUid == request.auth.uid;
    }

    match /workOrders/{orderId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.ownerUid == request.auth.uid);
      allow create: if isAuthenticated() && (isAdmin() || request.resource.data.ownerUid == request.auth.uid) && isValidWorkOrder(request.resource.data);
      allow update: if isAuthenticated() && (isAdmin() || resource.data.ownerUid == request.auth.uid) && isValidWorkOrder(request.resource.data);
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.ownerUid == request.auth.uid);
    }

    match /products/{productId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.ownerUid == request.auth.uid);
      allow create: if isAuthenticated() && (isAdmin() || request.resource.data.ownerUid == request.auth.uid) && isValidProduct(request.resource.data);
      allow update: if isAuthenticated() && (isAdmin() || request.resource.data.ownerUid == request.auth.uid) && isValidProduct(request.resource.data);
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.ownerUid == request.auth.uid);
    }

    match /presets/{presetId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.ownerUid == request.auth.uid);
      allow create: if isAuthenticated() && (isAdmin() || request.resource.data.ownerUid == request.auth.uid) && isValidPreset(request.resource.data);
      allow update: if isAuthenticated() && (isAdmin() || request.resource.data.ownerUid == request.auth.uid) && isValidPreset(request.resource.data);
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.ownerUid == request.auth.uid);
    }

    match /discounts/{discountId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.ownerUid == request.auth.uid);
      allow create: if isAuthenticated() && (isAdmin() || request.resource.data.ownerUid == request.auth.uid) && isValidDiscount(request.resource.data);
      allow update: if isAuthenticated() && (isAdmin() || request.resource.data.ownerUid == request.auth.uid) && isValidDiscount(request.resource.data);
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.ownerUid == request.auth.uid);
    }

    match /nameTagFonts/{fontId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidNameTagFont(request.resource.data);
      allow update: if isAdmin() && isValidNameTagFont(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
