{
  "entities": {
    "workOrders": {
      "title": "Work Order",
      "description": "A baby hand and foot casting work order.",
      "type": "object",
      "properties": {
        "customerName": { "type": "string", "description": "Name of the customer" },
        "contactInfo": { "type": "string", "description": "Contact information of the customer" },
        "babyName": { "type": "string", "description": "Name of the baby" },
        "babyAge": { "type": "string", "description": "Age of the baby" },
        "castingType": { "type": "string", "enum": ["hands", "feet", "both"], "description": "Type of casting" },
        "frameChoice": { "type": "string", "description": "Choice of frame or display" },
        "materialChoice": { "type": "string", "description": "Choice of material or color" },
        "orderDate": { "type": "string", "format": "date-time", "description": "Date of the order" },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed", "delivered"], "description": "Status of the order" },
        "notes": { "type": "string", "description": "Additional notes" },
        "ownerUid": { "type": "string", "description": "UID of the owner who created this order" }
      },
      "required": ["customerName", "contactInfo", "babyName", "castingType", "orderDate", "status", "ownerUid"]
    }
  },
  "firestore": {
    "/workOrders/{orderId}": {
      "schema": "workOrders",
      "description": "Collection of baby hand and foot casting work orders."
    }
  }
}
